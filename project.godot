; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mana overflow"
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameTick="*res://scripts/global_scripts/game_tick.gd"
GameEvents="*res://scripts/global_scripts/game_events.gd"
Stats="*res://scripts/global_scripts/stats.gd"
GameManager="*res://scripts/global_scripts/game_manager.gd"
AugmentManager="*res://scripts/global_scripts/augment_manager.gd"
Inventory="*res://scripts/global_scripts/inventory.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/always_on_top=true
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/MagicMacros/plugin.cfg", "res://addons/anthonyec.camera_preview/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "red",
"res://resources/": "yellow",
"res://scripts/": "purple"
}

[gui]

theme/custom_font="uid://b330csyhlvagr"
common/custom_font=""
common/custom=""
common/size/viewport_height=648
common/size/viewport_width=1152
common/stretch/scale=2.5

[rendering]

textures/canvas_textures/default_texture_filter=0
