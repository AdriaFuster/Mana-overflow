; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Mana overflow"
run/main_scene="res://scenes/game.tscn"
config/features=PackedStringArray("4.4", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameEvents="*res://scripts/global_scripts/game_events.gd"
Stats="*res://scripts/global_scripts/stats.gd"
GameTick="*res://scripts/global_scripts/game_tick.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/always_on_top=true
window/stretch/mode="viewport"
window/stretch/scale=6.0

[editor_plugins]

enabled=PackedStringArray("res://addons/MagicMacros/plugin.cfg", "res://addons/anthonyec.camera_preview/plugin.cfg", "res://addons/script-ide/plugin.cfg")

[file_customization]

folder_colors={
"res://addons/": "gray",
"res://assets/": "red",
"res://resources/": "yellow",
"res://scripts/": "purple"
}

[gui]

theme/custom_font="uid://b330csyhlvagr"
common/custom_font=""
common/custom=""
common/size/viewport_height=648
common/size/viewport_width=1152
common/stretch/scale=2.5

[rendering]

textures/canvas_textures/default_texture_filter=0
